{
  "name": "2wowd",
  "version": "0.1.0",
  "private": true,
  "description": "2D Isometric MMO inspired by World of Warcraft",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:client": "npm run dev -w packages/client",
    "build": "npm run build -w packages/shared && concurrently \"npm run build -w packages/server\" \"npm run build -w packages/client\"",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:client": "npm run build -w packages/client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
