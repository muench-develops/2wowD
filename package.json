{
  "name": "isoheim",
  "version": "0.1.0",
  "private": true,
  "description": "2D Isometric MMO built with TypeScript, Phaser.js & Node.js",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev -w packages/server",
    "dev:client": "npm run dev -w packages/client",
    "build": "npm run build -w packages/shared && concurrently \"npm run build -w packages/server\" \"npm run build -w packages/client\"",
    "build:shared": "npm run build -w packages/shared",
    "build:server": "npm run build -w packages/server",
    "build:client": "npm run build -w packages/client",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "markdownlint-cli": "^0.48.0",
    "typescript": "^5.7.0"
  }
}
